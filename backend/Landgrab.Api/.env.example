# Required
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=landgrab;Username=postgres;Password=your_password
Jwt__Secret=your-secret-key-must-be-at-least-64-characters-long-for-hmac-sha256

# Optional - defaults shown
Jwt__Issuer=landgrab
Jwt__Audience=landgrab
App__BaseUrl=http://localhost:5173

# Optional - Azure services (omit to use local alternatives)
# Azure__SignalR__ConnectionString=Endpoint=https://your-signalr.service.signalr.net;AccessKey=...
# AzureCommunicationServices__ConnectionString=endpoint=https://your-acs.communication.azure.com/;accesskey=...
# AllowedOrigins__0=https://your-production-domain.com
