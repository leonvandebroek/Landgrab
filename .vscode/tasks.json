{
    "version": "2.0.0",
    "tasks": [
        // ── Database ─────────────────────────────────────────────────────────
        {
            "label": "db: start postgres",
            "type": "shell",
            "command": "docker compose up db -d",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "presentation": {
                "reveal": "silent"
            }
        },
        {
            "label": "db: stop postgres",
            "type": "shell",
            "command": "docker compose stop db",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "presentation": {
                "reveal": "silent"
            }
        },
        // ── Backend ───────────────────────────────────────────────────────────
        {
            "label": "backend: build",
            "type": "shell",
            "command": "dotnet build --configuration Debug",
            "options": {
                "cwd": "${workspaceFolder}/backend/Landgrab.Api"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "backend: watch",
            "type": "shell",
            "command": "dotnet watch run --urls http://localhost:5000",
            "options": {
                "cwd": "${workspaceFolder}/backend/Landgrab.Api",
                "env": {
                    "ASPNETCORE_ENVIRONMENT": "Development",
                    "ConnectionStrings__DefaultConnection": "Host=localhost;Database=landgrab;Username=postgres;Password=postgres"
                }
            },
            "isBackground": true,
            "problemMatcher": {
                "owner": "dotnet-watch",
                "pattern": {
                    "regexp": "^\\s*(error|warning)\\s+(\\w+\\d+):\\s+(.*)$",
                    "severity": 1,
                    "code": 2,
                    "message": 3
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "Building\\.\\.\\.",
                    "endsPattern": "Now listening on:"
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            }
        },
        // ── Frontend ──────────────────────────────────────────────────────────
        {
            "label": "frontend: install",
            "type": "shell",
            "command": "npm install",
            "options": {
                "cwd": "${workspaceFolder}/frontend/landgrab-ui"
            },
            "problemMatcher": []
        },
        {
            "label": "frontend: dev",
            "type": "shell",
            "command": "npm run dev",
            "options": {
                "cwd": "${workspaceFolder}/frontend/landgrab-ui"
            },
            "isBackground": true,
            "problemMatcher": {
                "owner": "vite",
                "pattern": {
                    "regexp": "."
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "VITE v",
                    "endsPattern": "Local:\\s+http://localhost"
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            }
        },
        {
            "label": "frontend: lint",
            "type": "shell",
            "command": "npm run lint",
            "options": {
                "cwd": "${workspaceFolder}/frontend/landgrab-ui"
            },
            "problemMatcher": [
                "$eslint-stylish"
            ]
        },
        // ── Compound ──────────────────────────────────────────────────────────
        {
            "label": "start-dev-services",
            "detail": "Start Postgres + Vite dev server (used by Full Stack compound launch)",
            "dependsOn": [
                "db: start postgres",
                "frontend: dev"
            ],
            "dependsOrder": "parallel",
            "problemMatcher": []
        },
        // ── EF Core ───────────────────────────────────────────────────────────
        {
            "label": "ef: add migration",
            "type": "shell",
            "command": "dotnet ef migrations add ${input:migrationName}",
            "options": {
                "cwd": "${workspaceFolder}/backend/Landgrab.Api",
                "env": {
                    "ConnectionStrings__DefaultConnection": "Host=localhost;Database=landgrab;Username=postgres;Password=postgres"
                }
            },
            "problemMatcher": []
        },
        {
            "label": "ef: update database",
            "type": "shell",
            "command": "dotnet ef database update",
            "options": {
                "cwd": "${workspaceFolder}/backend/Landgrab.Api",
                "env": {
                    "ConnectionStrings__DefaultConnection": "Host=localhost;Database=landgrab;Username=postgres;Password=postgres"
                }
            },
            "problemMatcher": []
        }
    ],
    "inputs": [
        {
            "id": "migrationName",
            "type": "promptString",
            "description": "EF Core migration name"
        }
    ]
}